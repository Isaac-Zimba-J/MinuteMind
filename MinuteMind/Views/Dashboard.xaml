<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MinuteMind.Views.Dashboard"
             BackgroundColor="#F7F7F7">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="24,18,24,12" Spacing="24">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <Label Text="MinuteMind"
                           FontFamily="PlusJakartaBold"
                           FontSize="22"
                           TextColor="{StaticResource Primary}"
                           VerticalOptions="Center"/>

                    <Border Grid.Column="1"
                            WidthRequest="46"
                            HeightRequest="46"
                            BackgroundColor="#17313B"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 23">
                        <Image Source="profile.png"
                               HeightRequest="30"
                               WidthRequest="30"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Hero -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="Capture Clarity."
                           FontFamily="PlusJakartaBold"
                           FontSize="32"
                           TextColor="{StaticResource TextColorDark}"/>

                    <Label Text="Your intelligence architect is ready to transcribe your next big idea."
                           FontFamily="PlusJakartaRegular"
                           FontSize="15"
                           TextColor="#5C6470"
                           LineHeight="1.4"/>
                </VerticalStackLayout>

                <!-- Actions -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">

                    <Border BackgroundColor="{StaticResource Primary}"
                            HeightRequest="180"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 28">
                        <VerticalStackLayout Padding="10" Spacing="18">
                            <Border WidthRequest="60"
                                    HeightRequest="60"
                                    BackgroundColor="#3A98F3"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 30">
                                <Image Source="mic.png"
                                       HeightRequest="24"
                                       WidthRequest="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <Label Text="Record Meeting"
                                   FontFamily="PlusJakartaBold"
                                   FontSize="18"
                                   TextColor="White"/>

                            <Label Text="Live transcription"
                                   FontFamily="PlusJakartaRegular"
                                   FontSize="14"
                                   TextColor="#DDEEFF"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="White"
                            HeightRequest="180"
                            StrokeThickness="0"
                            Shadow="0,6,18,#14000000"
                            StrokeShape="RoundRectangle 28">
                        <VerticalStackLayout Padding="22" Spacing="18">
                            <Border WidthRequest="60"
                                    HeightRequest="60"
                                    BackgroundColor="#EDF4FD"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 30">
                                <Image Source="upload.png"
                                       HeightRequest="24"
                                       WidthRequest="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <Label Text="Upload&#10;Audio"
                                   FontFamily="PlusJakartaBold"
                                   FontSize="18"
                                   TextColor="#111111"/>

                            <Label Text="MP3, WAV, M4A"
                                   FontFamily="PlusJakartaRegular"
                                   FontSize="14"
                                   TextColor="#7A7F87"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Recent Meetings -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Recent Meetings"
                           FontFamily="PlusJakartaBold"
                           FontSize="18"
                           TextColor="#111111"/>
                    <Label Grid.Column="1"
                           Text="VIEW ALL"
                           FontFamily="PlusJakartaSemiBold"
                           FontSize="13"
                           TextColor="{StaticResource Primary}"
                           VerticalOptions="Center"/>
                </Grid>

                <VerticalStackLayout Spacing="16">

                    <!-- Card template -->
                    <Border BackgroundColor="White"
                            Padding="18"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                        <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="14">
                            <Border WidthRequest="52"
                                    HeightRequest="52"
                                    BackgroundColor="#F1F2F4"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16">
                                <Image Source="doc.png"
                                       HeightRequest="20"
                                       WidthRequest="20"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Product Sync"
                                       FontFamily="PlusJakartaSemiBold"
                                       FontSize="17"
                                       TextColor="#111111"/>
                                <Label Text="Oct 24, 2026"
                                       FontFamily="PlusJakartaRegular"
                                       FontSize="13"
                                       TextColor="#7A7F87"/>
                                <Border BackgroundColor="#DCEBFF"
                                        Padding="12,5"
                                        HorizontalOptions="Start"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 18">
                                    <Label Text="MINUTES READY"
                                           FontFamily="PlusJakartaBold"
                                           FontSize="11"
                                           TextColor="#5B79A4"/>
                                </Border>
                            </VerticalStackLayout>

                            <Image Grid.Column="2"
                                   Source="chevron.png"
                                   HeightRequest="18"
                                   WidthRequest="18"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <Border BackgroundColor="White" Padding="18" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                        <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="14">
                            <Border WidthRequest="52" HeightRequest="52" BackgroundColor="#F1F2F4" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                <Image Source="chat.png" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Client Kickoff" FontFamily="PlusJakartaSemiBold" FontSize="17"/>
                                <Label Text="Oct 23, 2026" FontFamily="PlusJakartaRegular" FontSize="13" TextColor="#7A7F87"/>
                                <Border BackgroundColor="#F0F1F2" Padding="12,5" HorizontalOptions="Start" StrokeThickness="0" StrokeShape="RoundRectangle 18">
                                    <Label Text="TRANSCRIBED" FontFamily="PlusJakartaBold" FontSize="11" TextColor="#6B717B"/>
                                </Border>
                            </VerticalStackLayout>
                            <Image Grid.Column="2" Source="chevron.png" HeightRequest="18" WidthRequest="18" VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <Border BackgroundColor="White" Padding="18" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                        <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="14">
                            <Border WidthRequest="52" HeightRequest="52" BackgroundColor="#F1F2F4" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                <Image Source="brain.png" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Brainstorming Session" FontFamily="PlusJakartaSemiBold" FontSize="17"/>
                                <Label Text="Oct 21, 2026" FontFamily="PlusJakartaRegular" FontSize="13" TextColor="#7A7F87"/>
                                <Border BackgroundColor="#DCEBFF" Padding="12,5" HorizontalOptions="Start" StrokeThickness="0" StrokeShape="RoundRectangle 18">
                                    <Label Text="MINUTES READY" FontFamily="PlusJakartaBold" FontSize="11" TextColor="#5B79A4"/>
                                </Border>
                            </VerticalStackLayout>
                            <Image Grid.Column="2" Source="chevron.png" HeightRequest="18" WidthRequest="18" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- AI Status -->
                <VerticalStackLayout Padding="0,18" Spacing="10" HorizontalOptions="Center">
                    <Image Source="sparkle.png" HeightRequest="44" WidthRequest="44" Opacity="0.7"/>
                    <Label Text="INTELLIGENT ANALYSIS ACTIVE"
                           FontFamily="PlusJakartaRegular"
                           FontSize="13"
                         
                           TextColor="#A5A9B0"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
