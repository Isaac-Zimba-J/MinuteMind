<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MinuteMind.Models"
             x:Class="MinuteMind.Views.TranscriptPage"
             BackgroundColor="{StaticResource Surface}"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="64,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              Padding="16,0"
              VerticalOptions="Center"
              BackgroundColor="{StaticResource Surface}">

            <!-- Back button -->
            <Border WidthRequest="40"
                    HeightRequest="40"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Border.GestureRecognizers>
                <Label Text="&#x2190;"
                       FontSize="22"
                       TextColor="{StaticResource OnSurface}"
                       Opacity="0.6"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <Label Grid.Column="1"
                   Text="Transcript"
                   FontFamily="PlusJakartaBold"
                   FontSize="24"
                   CharacterSpacing="0"
                   TextColor="{StaticResource Primary}"
                   VerticalOptions="Center"
                   Margin="12,0,0,0" />
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="24,0,24,24" Spacing="0">

                <!-- Meeting Info -->
                <VerticalStackLayout Spacing="8" Margin="0,0,0,40">
                    <Label Text="LIVE SESSION"
                           FontFamily="InterMedium"
                           FontSize="11"
                           CharacterSpacing="2"
                           TextColor="{StaticResource Primary}" />

                    <Label Text="{Binding MeetingTitle}"
                           FontFamily="PlusJakartaBold"
                           FontSize="32"
                           CharacterSpacing="0"
                           TextColor="{StaticResource OnSurface}" />

                    <Label Text="{Binding MeetingMeta}"
                           FontFamily="InterMedium"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceVariant}"
                           Margin="0,8,0,0" />
                </VerticalStackLayout>

                <!-- Transcript Segments -->
                <VerticalStackLayout Spacing="24"
                                     BindableLayout.ItemsSource="{Binding Segments}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:TranscriptSegment">
                            <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                                    Padding="24"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16">
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource OnSurfaceBrush}"
                                            Offset="0,12"
                                            Radius="32"
                                            Opacity="0.04" />
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="16">
                                    <!-- Timestamp -->
                                    <Label Text="{Binding TimestampDisplay}"
                                           FontFamily="InterSemiBold"
                                           FontSize="11"
                                           CharacterSpacing="1"
                                           TextColor="{StaticResource Primary}"
                                           BackgroundColor="#0D005FAA"
                                           Padding="8,4" />
yes
                                    <!-- Speaker + Text -->
                                    <Grid ColumnDefinitions="40,*" ColumnSpacing="16">
                                        <!-- Speaker avatar -->
                                        <Border WidthRequest="40"
                                                HeightRequest="40"
                                                BackgroundColor="{StaticResource SurfaceContainer}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12">
                                            <Label Text="{Binding Speaker, StringFormat='{0:0}'}"
                                                   FontFamily="PlusJakartaBold"
                                                   FontSize="14"
                                                   TextColor="{StaticResource Primary}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="{Binding Speaker, StringFormat='{0}:'}"
                                                   FontFamily="PlusJakartaBold"
                                                   FontSize="14"
                                                   TextColor="{StaticResource OnSurface}" />
                                            <Label Text="{Binding Text}"
                                                   FontFamily="InterRegular"
                                                   FontSize="16"
                                                   LineHeight="1.6"
                                                   TextColor="{StaticResource OnSurfaceVariant}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Floating Generate Minutes Button -->
        <Border Grid.Row="2"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 28"
                Padding="32,16"
                HorizontalOptions="Center"
                Margin="0,0,0,40">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource PrimaryContainer}" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="{StaticResource PrimaryBrush}"
                        Offset="0,12"
                        Radius="32"
                        Opacity="0.3" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding GenerateMinutesCommand}" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Image Source="sparkle.png"
                       HeightRequest="20"
                       WidthRequest="20"
                       VerticalOptions="Center" />
                <Label Text="Generate Minutes"
                       FontFamily="PlusJakartaBold"
                       FontSize="14"
                       TextColor="{StaticResource OnPrimary}"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

    </Grid>

</ContentPage>
