<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MinuteMind.Views.ProcessingPage"
             Title="Processing"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False">
    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
        <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}" />
        <Label Text="Processing..." Style="{StaticResource HeadlineLarge}" HorizontalTextAlignment="Center" />
    </VerticalStackLayout>
</ContentPage>
