<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="MinuteMind.Views.Dashboard"
             BackgroundColor="{StaticResource Surface}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="64,*">

        <!-- Fixed Header -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              Padding="24,0"
              VerticalOptions="Center"
              BackgroundColor="{StaticResource Surface}">

            <Label Text="&#x2630;"
                   FontSize="24"
                   TextColor="{StaticResource Primary}"
                   VerticalOptions="Center" />

            <Label Grid.Column="1"
                   Text="MinuteMind"
                   FontFamily="PlusJakartaBold"
                   FontSize="24"
                   CharacterSpacing="0"
                   TextColor="{StaticResource Primary}"
                   VerticalOptions="Center"
                   Margin="16,0,0,0" />

            <Border Grid.Column="2"
                    WidthRequest="40"
                    HeightRequest="40"
                    BackgroundColor="{StaticResource SecondaryContainer}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                <Image Source="user.png"
                       Aspect="AspectFill"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- Scrollable Content -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="24,0,24,24">

                <!-- Hero / Greeting -->
                <VerticalStackLayout Spacing="8" Margin="0,0,0,40">
                    <Label Text="Capture Clarity."
                           FontFamily="PlusJakartaBold"
                           FontSize="36"
                           CharacterSpacing="0"
                           TextColor="{StaticResource OnSurface}" />

                    <Label Text="Your intelligence architect is ready to transcribe your next big idea."
                           Style="{StaticResource BodyMedium}"
                           LineHeight="1.5" />
                </VerticalStackLayout>

                <!-- Quick Actions Bento Grid -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="16" Margin="0,0,0,48">

                    <!-- Record Meeting Card -->
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 32"
                            HeightRequest="{Binding Source={RelativeSource Self}, Path=Width}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding RecordMeetingCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                                <GradientStop Color="{StaticResource PrimaryContainer}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource PrimaryBrush}"
                                    Offset="0,8"
                                    Radius="24"
                                    Opacity="0.15" />
                        </Border.Shadow>
                        <Grid Padding="24" RowDefinitions="Auto,*,Auto">
                            <!-- Icon -->
                            <Border WidthRequest="48"
                                    HeightRequest="48"
                                    BackgroundColor="#33FFFFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 24"
                                    HorizontalOptions="Start">
                                <Image Source="mic.png"
                                       HeightRequest="24"
                                       WidthRequest="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <!-- Spacer (pushes text to bottom) -->
                            <BoxView Grid.Row="1">
                                <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                                <GradientStop Color="{StaticResource PrimaryContainer}" Offset="1.0" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                            </BoxView>
                            <!-- Text -->
                            <VerticalStackLayout Grid.Row="2" Spacing="4">
                                <Label Text="Record Meeting"
                                       FontFamily="PlusJakartaBold"
                                       FontSize="18"
                                       TextColor="{StaticResource OnPrimary}" />
                                <Label Text="Live transcription"
                                       FontFamily="InterRegular"
                                       FontSize="14"
                                       TextColor="#B3FFFFFF" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Upload Audio Card -->
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource SurfaceContainerLowest}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 32"
                            HeightRequest="{Binding Source={RelativeSource Self}, Path=Width}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding UploadAudioCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource OnSurfaceBrush}"
                                    Offset="0,12"
                                    Radius="32"
                                    Opacity="0.04" />
                        </Border.Shadow>
                        <Grid Padding="24" RowDefinitions="Auto,*,Auto">
                            <!-- Icon -->
                            <Border WidthRequest="48"
                                    HeightRequest="48"
                                    BackgroundColor="#4DB8D3FD"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 24"
                                    HorizontalOptions="Start">
                                <Image Source="upload.png"
                                       HeightRequest="24"
                                       WidthRequest="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <!-- Spacer -->
                            <BoxView Grid.Row="1" Color="{StaticResource SurfaceContainerLowest}" />
                            <!-- Text -->
                            <VerticalStackLayout Grid.Row="2" Spacing="4">
                                <Label Text="Upload Audio"
                                       FontFamily="PlusJakartaBold"
                                       FontSize="18"
                                       TextColor="{StaticResource OnSurface}" />
                                <Label Text="MP3, WAV, M4A"
                                       Style="{StaticResource BodyMedium}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Recent Meetings Header -->
                <Grid ColumnDefinitions="*,*" Margin="0,0,0,24">
                    <Label Text="Recent Meetings"
                           FontFamily="PlusJakartaBold"
                           FontSize="20"
                           CharacterSpacing="0"
                           TextColor="{StaticResource OnSurface}" />
                    <Label Grid.Column="1"
                           Style="{StaticResource LabelSmall}"
                           Text="VIEW ALL"
                           CharacterSpacing="0"
                           HorizontalOptions="End"
                           TextColor="{StaticResource Primary}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ViewAllMeetingsCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <!-- Meeting Cards -->
                <VerticalStackLayout Spacing="16">

                    <!-- Card 1: Product Sync -->
                    <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                            Padding="20"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenMeetingCommand}">
                                <TapGestureRecognizer.CommandParameter>
                                    <x:Int32>1</x:Int32>
                                </TapGestureRecognizer.CommandParameter>
                            </TapGestureRecognizer>
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource OnSurfaceBrush}"
                                    Offset="0,12"
                                    Radius="32"
                                    Opacity="0.04" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="16">
                            <Border WidthRequest="56"
                                    HeightRequest="56"
                                    BackgroundColor="{StaticResource SurfaceContainer}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16">
                                <Image Source="doc.png"
                                       HeightRequest="22"
                                       WidthRequest="22"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="Product Sync"
                                       FontFamily="PlusJakartaSemiBold"
                                       FontSize="16"
                                       TextColor="{StaticResource OnSurface}"
                                       LineBreakMode="TailTruncation" />
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Label Text="Oct 24, 2026"
                                           FontFamily="InterRegular"
                                           FontSize="12"
                                           TextColor="{StaticResource OnSurfaceVariant}" />
                                    <Border WidthRequest="4"
                                            HeightRequest="4"
                                            BackgroundColor="{StaticResource OutlineVariant}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 2"
                                            VerticalOptions="Center" />
                                    <Border BackgroundColor="#80B8D3FD"
                                            Padding="8,3"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12">
                                        <Label Text="MINUTES READY"
                                               FontFamily="InterSemiBold"
                                               FontSize="10"
                                               CharacterSpacing="0"
                                               TextColor="{StaticResource OnSecondaryContainer}" />
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <Image Grid.Column="2"
                                   Source="chevron.png"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Card 2: Client Kickoff -->
                    <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                            Padding="20"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenMeetingCommand}">
                                <TapGestureRecognizer.CommandParameter>
                                    <x:Int32>2</x:Int32>
                                </TapGestureRecognizer.CommandParameter>
                            </TapGestureRecognizer>
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource OnSurfaceBrush}"
                                    Offset="0,12"
                                    Radius="32"
                                    Opacity="0.04" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="16">
                            <Border WidthRequest="56"
                                    HeightRequest="56"
                                    BackgroundColor="{StaticResource SurfaceContainer}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16">
                                <Image Source="chat.png"
                                       HeightRequest="22"
                                       WidthRequest="22"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="Client Kickoff"
                                       FontFamily="PlusJakartaSemiBold"
                                       FontSize="16"
                                       TextColor="{StaticResource OnSurface}"
                                       LineBreakMode="TailTruncation" />
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Label Text="Oct 23, 2026"
                                           FontFamily="InterRegular"
                                           FontSize="12"
                                           TextColor="{StaticResource OnSurfaceVariant}" />
                                    <Border WidthRequest="4"
                                            HeightRequest="4"
                                            BackgroundColor="{StaticResource OutlineVariant}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 2"
                                            VerticalOptions="Center" />
                                    <Border BackgroundColor="{StaticResource SurfaceContainerHigh}"
                                            Padding="8,3"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12">
                                        <Label Text="TRANSCRIBED"
                                               FontFamily="InterSemiBold"
                                               FontSize="10"
                                               CharacterSpacing="0"
                                               TextColor="{StaticResource OnSurfaceVariant}" />
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <Image Grid.Column="2"
                                   Source="chevron.png"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Card 3: Brainstorming Session -->
                    <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                            Padding="20"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenMeetingCommand}">
                                <TapGestureRecognizer.CommandParameter>
                                    <x:Int32>3</x:Int32>
                                </TapGestureRecognizer.CommandParameter>
                            </TapGestureRecognizer>
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource OnSurfaceBrush}"
                                    Offset="0,12"
                                    Radius="32"
                                    Opacity="0.04" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="16">
                            <Border WidthRequest="56"
                                    HeightRequest="56"
                                    BackgroundColor="{StaticResource SurfaceContainer}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16">
                                <Image Source="brain.png"
                                       HeightRequest="22"
                                       WidthRequest="22"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="Brainstorming Session"
                                       FontFamily="PlusJakartaSemiBold"
                                       FontSize="16"
                                       TextColor="{StaticResource OnSurface}"
                                       LineBreakMode="TailTruncation" />
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Label Text="Oct 21, 2026"
                                           FontFamily="InterRegular"
                                           FontSize="12"
                                           TextColor="{StaticResource OnSurfaceVariant}" />
                                    <Border WidthRequest="4"
                                            HeightRequest="4"
                                            BackgroundColor="{StaticResource OutlineVariant}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 2"
                                            VerticalOptions="Center" />
                                    <Border BackgroundColor="#80B8D3FD"
                                            Padding="8,3"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12">
                                        <Label Text="MINUTES READY"
                                               FontFamily="InterSemiBold"
                                               FontSize="10"
                                               CharacterSpacing="0"
                                               TextColor="{StaticResource OnSecondaryContainer}" />
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <Image Grid.Column="2"
                                   Source="chevron.png"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- AI Pulse Indicator -->
                <VerticalStackLayout Margin="0,48,0,0" Spacing="16" HorizontalOptions="Center" Opacity="0.4">
                    <Image Source="sparkle.png"
                           HeightRequest="32"
                           WidthRequest="32"
                           HorizontalOptions="Center" />
                    <Label Text="INTELLIGENT ANALYSIS ACTIVE"
                           Style="{StaticResource LabelSmall}"
                           CharacterSpacing="0"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
